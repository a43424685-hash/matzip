# 이 파일을 .env 로 복사해서 채우세요:  cp .env.example .env
# (.env 는 git 에 올라가지 않습니다)

# ── 데이터베이스 (Supabase Postgres) ─────────────────────────
# 런타임은 트랜잭션 풀러(6543), 마이그레이션/seed 는 세션 풀러(5432) 사용.
# Supabase → Connect → ORMs → Prisma 에서 복사. 비밀번호에 특수문자(@,! 등)가 있으면 URL 인코딩 필요(@=%40, !=%21).
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── 세션/보안 ────────────────────────────────────────────────
# 세션 쿠키 서명용. 운영은 반드시 긴 랜덤값. 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-secret"

# 랭킹 배치 크론 보호. 설정하면 /api/cron/refresh-rankings 가 잠기고 Vercel Cron 만 호출 가능.
# 운영(production)에서는 반드시 설정해야 함(없으면 크론 엔드포인트가 거부됨).
CRON_SECRET="change-me-to-a-random-secret"

# ── 카카오 ──────────────────────────────────────────────────
# 장소/주소 검색(서버) + OAuth client_id 로도 사용. Developers → 앱 → REST API 키.
KAKAO_REST_API_KEY=""
# 지도 표시(브라우저). 같은 앱의 "JavaScript 키". NEXT_PUBLIC_ 접두사 필수(빌드 시 인라인).
NEXT_PUBLIC_KAKAO_JS_KEY=""
# 카카오 로그인. Developers → 카카오 로그인 → 보안 Client Secret + Redirect URI 등록.
KAKAO_CLIENT_SECRET=""
KAKAO_REDIRECT_URI="https://<your-domain>/api/auth/kakao/callback"

# 앱 공개 주소. 이메일 인증 링크/카카오 redirect 기본값. 운영은 Vercel 도메인.
APP_URL="https://<your-domain>"

# ── 스토리지 (Supabase Storage) ─────────────────────────────
# local = 로컬 디스크(dev) / supabase = 운영. supabase 면 아래 3개 필수.
STORAGE_DRIVER="supabase"
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_KEY=""        # service_role 키 (서버 전용, 절대 클라이언트 노출 금지)
SUPABASE_BUCKET="media"

# ── 증거 인증 AI 검증 (선택) ────────────────────────────────
# 영수증 OCR 대조 / 메뉴 관련성 검증용 Anthropic 키. 없으면 검증 건너뜀(첨부는 허용).
ANTHROPIC_API_KEY=""
