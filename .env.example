# 이 파일을 .env 로 복사해서 사용하세요:  cp .env.example .env

# SQLite for zero-config local MVP. Swap to Postgres later by changing provider + url.
DATABASE_URL="file:./dev.db"

# 세션 쿠키 서명용 비밀키 — 운영 시 반드시 안전한 랜덤 값으로 교체하세요.
# 예) node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-secret"

# 장소 검색(가게 좌표 확보 → 위치 인증).
# 비워두면 무료 OSM Nominatim 사용. 카카오 REST 키를 넣으면 카카오 로컬을 우선 사용(한국 정확도↑).
# https://developers.kakao.com → 앱 → REST API 키
KAKAO_REST_API_KEY=""

# 앱 공개 주소. 이메일 인증 링크/카카오 redirect 기본값에 사용.
APP_URL="http://localhost:3000"

# 카카오 로그인. Developers → 제품 설정 → 카카오 로그인 활성화 후 Redirect URI 등록:
# http://localhost:3000/api/auth/kakao/callback
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
KAKAO_REDIRECT_URI="http://localhost:3000/api/auth/kakao/callback"
